<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <style>
    :root {
      --cb-primary: {{ branding.primary }};
      --cb-secondary: {{ branding.secondary }};
      --cb-accent: {{ branding.accent }};
      --cb-text: {{ branding.text }};
      --cb-background: {{ branding.background }};
      --cb-muted: {{ branding.muted }};
    }
    html { background: var(--cb-background); color: var(--cb-text); }
    body {
      max-width: 820px;
      margin: 2rem auto;
      padding: 0 1.5rem;
      font-family: {{ branding.font_family_body }};
      line-height: 1.55;
    }
    h1, h2, h3, h4 {
      font-family: {{ branding.font_family_headings }};
      color: var(--cb-primary);
      line-height: 1.25;
    }
    h1 { border-bottom: 2px solid var(--cb-primary); padding-bottom: 0.4rem; }
    h2 { margin-top: 2rem; border-bottom: 1px solid var(--cb-muted); padding-bottom: 0.2rem; }
    h3 { margin-top: 1.5rem; color: var(--cb-secondary); }
    a { color: var(--cb-secondary); }
    blockquote {
      border-left: 4px solid var(--cb-accent);
      margin: 1rem 0;
      padding: 0.5rem 1rem;
      background: rgba(0, 0, 0, 0.025);
      color: var(--cb-text);
    }
    code { background: rgba(0, 0, 0, 0.05); padding: 0.1rem 0.3rem; border-radius: 3px; }
    table {
      border-collapse: collapse;
      width: 100%;
      margin: 1rem 0;
      font-size: 0.95rem;
    }
    th, td { border: 1px solid var(--cb-muted); padding: 0.4rem 0.6rem; text-align: left; vertical-align: top; }
    th { background: var(--cb-primary); color: var(--cb-background); }
    hr { border: 0; border-top: 1px solid var(--cb-muted); margin: 2rem 0; }
    footer { margin-top: 2rem; color: var(--cb-muted); font-size: 0.85rem; }
  </style>
</head>
<body>
{{ body_html }}
</body>
</html>
